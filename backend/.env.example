# Copy this file to .env and fill in real values.
# Never commit .env; only commit .env.example.

# Required. Use a unique secret value per environment.
SECRET_KEY=

# DEBUG=True is only for local development. Use DEBUG=False in production.
DEBUG=True

# PostgreSQL connection string. Supabase is used only as managed PostgreSQL.
DATABASE_URL=

# Comma-separated list of allowed hostnames.
# Leave empty for local dev (Django allows localhost by default when DEBUG=True).
ALLOWED_HOSTS=

# Comma-separated list of frontend origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Comma-separated list of HTTPS origins trusted for CSRF when needed.
CSRF_TRUSTED_ORIGINS=

# HTTPS/proxy flags. Keep False locally; enable only behind HTTPS in production.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
USE_X_FORWARDED_PROTO=False

# Security headers / HSTS.
# Keep HSTS disabled locally (SECURE_HSTS_SECONDS=0). In production, only enable
# HSTS once the entire domain is reliably served over HTTPS — once a browser
# receives HSTS it will refuse plain HTTP for the duration of SECURE_HSTS_SECONDS.
# Recommended production value: 31536000 (1 year).
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# SECURE_HSTS_PRELOAD submits the domain to browser preload lists. Only enable
# if you understand the impact: removal from preload lists is slow and manual.
SECURE_HSTS_PRELOAD=False
# SECURE_CONTENT_TYPE_NOSNIFF should normally stay True in every environment;
# it blocks MIME-type sniffing attacks and has no downside for typical apps.
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
# X_FRAME_OPTIONS=DENY prevents Axis from being embedded in any iframe
# (clickjacking protection). Only change this intentionally if you need to
# embed the app somewhere trusted.
X_FRAME_OPTIONS=DENY

# Never run seed_dev in production.
# bootstrap_roles is safe for production and creates only required auth groups.
